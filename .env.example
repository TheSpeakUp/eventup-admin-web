# EventUp admin web — env reference
#
# Local dev: copy to .env.local, leave mock flags on, no backend required.
# Prod: managed via /etc/eventup-admin-web/env on origin (NOT this file).
#       PORT=3001, NEXT_PUBLIC_API_URL=https://api.speak-up.pro.

# Backend base URL (no trailing slash). Default = local dev API.
NEXT_PUBLIC_API_URL=http://localhost:8002

# Mock auth — login form accepts admin@example.com / password without backend.
NEXT_PUBLIC_USE_MOCK_AUTH=false

# Mock backend — msw intercepts /admin/v2/marketplace/* calls (browser + server).
# With both mock flags on, app runs standalone with no backend at all.
NEXT_PUBLIC_USE_MOCK_BACKEND=false
