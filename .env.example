# EventUp admin web — local dev env

# Backend base URL (no trailing slash).
# Local dev:    http://localhost:8002
# Production:   https://api.speak-up.pro
NEXT_PUBLIC_API_URL=http://localhost:8002

# When true, login form accepts admin@example.com / password and skips
# the backend round-trip. Use until backend PR #A3 lands.
NEXT_PUBLIC_USE_MOCK_AUTH=false

# When true, msw intercepts all /admin/v2/services/* calls server-side
# (via instrumentation.ts) and in the browser. Use until backend PR #A5
# lands. With both mock flags on, the app runs standalone with no backend.
NEXT_PUBLIC_USE_MOCK_BACKEND=false
